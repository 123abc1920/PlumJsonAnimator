<UserControl
    x:Class="PlumJsonAnimator.Views.SettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    Background="{DynamicResource SukiBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0">
            <StackPanel>
                <Button
                    Name="ProjectBtn"
                    HorizontalAlignment="Stretch"
                    Click="ShowProjectSettings"
                    Content="{DynamicResource project_settings}" />
                <Button
                    Name="AppBtn"
                    HorizontalAlignment="Stretch"
                    Click="ShowAppSettings"
                    Content="{DynamicResource app_settings}" />
            </StackPanel>
        </ScrollViewer>

        <GridSplitter
            Grid.Column="1"
            Width="6"
            Background="Gray"
            ResizeDirection="Columns" />

        <ScrollViewer Grid.Column="2">
            <ContentControl Name="SettingsContentControl" />
        </ScrollViewer>
    </Grid>
</UserControl>
