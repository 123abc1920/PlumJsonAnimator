<UserControl
    x:Class="PlumJsonAnimator.Views.ExportPanelMP4"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:viewModels="clr-namespace:PlumJsonAnimator.ViewModels"
    Background="{DynamicResource SukiBackgroundBrush}">
    <StackPanel Margin="10" x:DataType="viewModels:MainWindowViewModel">

        <TextBlock Margin="0,5" Text="{DynamicResource ffmpeg_info}" />
        <TextBlock Margin="0,5" Text="{DynamicResource ffmpeg_path}" />
        <Grid ColumnDefinitions="*,Auto">
            <TextBox
                Name="ffmpegPath"
                Grid.Column="0"
                Margin="0,0,5,0"
                Text="{Binding FfmpegPath, Mode=TwoWay}"
                Watermark="{DynamicResource path}" />
            <Button
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="SelectFfmpeg">
                <iconPacks:PackIconBootstrapIcons Kind="FolderFill" />
            </Button>
        </Grid>

        <TextBlock Margin="0,5" Text="{DynamicResource export_path}" />
        <Grid ColumnDefinitions="*,Auto">
            <TextBox
                Name="path"
                Grid.Column="0"
                Margin="0,0,5,0"
                Watermark="{DynamicResource save_path}" />
            <Button
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="SelectFolder">
                <iconPacks:PackIconBootstrapIcons Kind="FolderFill" />
            </Button>
        </Grid>

        <TextBlock Margin="0,5" Text="{DynamicResource file_name}" />
        <TextBox Name="pName" Watermark="{DynamicResource mp4_name}" />

        <Grid Margin="0,5" ColumnDefinitions="*,*">
            <TextBlock
                Grid.Column="0"
                Margin="0,0,2.5,0"
                Text="{DynamicResource start_name}" />
            <TextBlock
                Grid.Column="1"
                Margin="2.5,0,0,0"
                Text="{DynamicResource end_name}" />
        </Grid>
        <Grid ColumnDefinitions="*,*">
            <TextBox
                Name="start"
                Grid.Column="0"
                Margin="0,0,2.5,0"
                Text="Converter={StaticResource DoubleConverter}" />
            <TextBox
                Name="end"
                Grid.Column="1"
                Margin="2.5,0,0,0"
                Text="Converter={StaticResource DoubleConverter}" />
        </Grid>

        <Button
            Margin="0,10"
            HorizontalAlignment="Center"
            Click="ExportAsMp4"
            Content="{DynamicResource export}" />

    </StackPanel>
</UserControl>
