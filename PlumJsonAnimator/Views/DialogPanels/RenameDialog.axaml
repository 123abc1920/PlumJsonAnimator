<UserControl
    x:Class="PlumJsonAnimator.Views.RenameDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:viewModels="clr-namespace:PlumJsonAnimator.ViewModels"
    Background="{DynamicResource SukiBackgroundBrush}">
    <StackPanel Margin="10" x:DataType="viewModels:MainWindowViewModel">
        <TextBox
            Name="name"
            Margin="0,5"
            Text="{Binding RedactObj.GetName, Mode=OneWay}" />
        <Button
            Margin="0,10"
            HorizontalAlignment="Center"
            Click="SetName"
            Content="{DynamicResource save}" />
    </StackPanel>
</UserControl>
