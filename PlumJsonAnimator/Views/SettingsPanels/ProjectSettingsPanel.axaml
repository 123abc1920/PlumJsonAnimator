<UserControl
    x:Class="PlumJsonAnimator.Views.ProjectSettingsPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:viewModels="clr-namespace:PlumJsonAnimator.ViewModels"
    Background="{DynamicResource SukiBackgroundBrush}">
    <StackPanel Margin="10" x:DataType="viewModels:AppSettingsViewModel">
        <TextBlock
            FontSize="16"
            FontWeight="Bold"
            Text="{DynamicResource project_settings}" />
        <TextBlock Margin="0,5" Text="{DynamicResource name}" />
        <TextBox
            Name="pName"
            Text="{Binding CurrentProject.Name, Mode=OneWay}"
            Watermark="{DynamicResource name}" />
        <TextBlock Margin="0,5" Text="{DynamicResource project_path}" />
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
            <TextBox
                Name="path"
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,5,0"
                Text="{Binding CurrentProject.ProjectPath, Mode=OneWay}"
                Watermark="{DynamicResource project_path}" />
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="SelectFolder">
                <iconPacks:PackIconBootstrapIcons Kind="FolderFill" />
            </Button>
        </Grid>
        <TextBlock Margin="0,5" Text="{DynamicResource spine_version_label}" />
        <TextBox
            Name="pVersion"
            Text="{Binding CurrentProject.MetaData.Spine, Mode=OneWay}"
            Watermark="{DynamicResource spine_version}" />
        <Button
            Margin="0,10"
            HorizontalAlignment="Center"
            Click="SaveSettings"
            Content="{DynamicResource save}" />
    </StackPanel>
</UserControl>
