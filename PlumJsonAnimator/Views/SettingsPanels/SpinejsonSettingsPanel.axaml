<UserControl
    x:Class="PlumJsonAnimator.Views.SpinejsonSettingsPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:viewModels="clr-namespace:PlumJsonAnimator.ViewModels"
    Background="{DynamicResource SukiBackgroundBrush}">
    <StackPanel Margin="10" x:DataType="viewModels:MainWindowViewModel">
        <TextBlock
            Margin="0,5"
            FontSize="16"
            FontWeight="Bold"
            Text="{DynamicResource app_settings}" />
        <TextBlock Text="{DynamicResource project_path}" />
        <Grid
            Margin="0,5"
            ColumnDefinitions="*,Auto"
            RowDefinitions="Auto,Auto">
            <TextBox
                Name="pathTextBox"
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,5,0"
                Text="{Binding CurrentProject.ProjectPath, Mode=OneWay}" />
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="SelectFolder">
                <iconPacks:PackIconBootstrapIcons Kind="FolderFill" />
            </Button>
        </Grid>

        <TextBlock Margin="0,5" Text="{DynamicResource app_theme}" />
        <ComboBox
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding Themes}"
            MaxDropDownHeight="100"
            SelectedItem="{Binding CurrentTheme, Mode=TwoWay}" />

        <TextBlock Margin="0,5" Text="{DynamicResource ffmpeg_path}" />
        <Grid
            Margin="0,5"
            ColumnDefinitions="*,Auto"
            RowDefinitions="Auto,Auto">
            <TextBox HorizontalAlignment="Stretch" Text="{Binding FfmpegPath, Mode=TwoWay}" />
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="SelectFfmpeg">
                <iconPacks:PackIconBootstrapIcons Kind="FolderFill" />
            </Button>
        </Grid>

        <TextBlock Margin="0,5" Text="{DynamicResource language}" />
        <ComboBox
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,5,5,0"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding Langs}"
            MaxDropDownHeight="100"
            SelectedItem="{Binding CurrentLang, Mode=TwoWay}" />

        <Button
            Margin="0,10"
            HorizontalAlignment="Center"
            Click="SaveSettings"
            Content="{DynamicResource save}" />
    </StackPanel>
</UserControl>
