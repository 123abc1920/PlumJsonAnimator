{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api",
      "filter": "filter.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "Assets/logo.ico",
          "Assets/logo_mini.svg"
        ]
      }
    ],
    "output": "../docs",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "PlumJsonAnimator",
      "_appTitle": "PlumJsonAnimator",
      "_appFaviconPath": "Assets/logo.ico",
      "_appLogoPath": "Assets/logo_mini.svg",
      "_enableSearch": true,
      "pdf": false
    }
  }
}