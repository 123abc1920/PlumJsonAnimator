<Application
    x:Class="PlumJsonAnimator.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PlumJsonAnimator"
    xmlns:models="clr-namespace:SukiUI.Models;assembly=SukiUI"
    xmlns:sukiUi="clr-namespace:SukiUI;assembly=SukiUI"
    RequestedThemeVariant="Default">
    <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <sukiUi:SukiTheme />
        <StyleInclude Source="avares://IconPacks.Avalonia.BootstrapIcons/BootstrapIcons.axaml" />

        <StyleInclude Source="avares://PlumJsonAnimator/Views/Themes/Theme.axaml" />
    </Application.Styles>
</Application>
