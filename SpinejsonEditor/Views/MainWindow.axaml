<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpinejsonEditor.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SpinejsonEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SpinejsonEditor">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

<DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_Open..."/>
        <Separator/>
        <MenuItem Header="_Exit"/>
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="Copy"/>
        <MenuItem Header="Paste"/>
      </MenuItem>
    </Menu>
    <Grid DockPanel.Dock="Bottom">
		<TextBlock Margin="0 5" FontSize="18" FontWeight="Bold">Heading</TextBlock>
	</Grid>
    <Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="3*"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
	            <Grid Grid.Column="0" Background="AliceBlue">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Background="LightBlue" Grid.Row="0" HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock FontSize="22" Background="LightBlue">Project Name</TextBlock>
                            <TextBox Name="projectName" Text="{Binding CurrentProject.Name}" Watermark="New Project" KeyDown="TextBox_KeyDown"/>
                            <TextBlock FontSize="22">Project Path</TextBlock>
                            <TextBox Name="projectPath" Text="{Binding CurrentProject.ProjectPath}" Watermark="Path" KeyDown="TextBox_KeyDown"/>
                        </StackPanel>
                    </ScrollViewer>
                    <GridSplitter Grid.Row="1" Background="Gray" Height="6" ResizeDirection="Rows"/>
                    <ScrollViewer Background="LightBlue" HorizontalAlignment="Stretch" Grid.Row="3" HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock FontSize="22" Height="100" Background="LightBlue">Block 1</TextBlock>
                            <TextBlock FontSize="22" Height="100">Block 2</TextBlock>
                            <TextBlock FontSize="22" Height="100" Background="LightBlue">Block 3</TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
	    <GridSplitter Grid.Column="1" Background="Gray" Width="6" ResizeDirection="Columns"/>
        <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <ScrollViewer Background="LightBlue" VerticalAlignment="Stretch" Grid.Row="0"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                            <Canvas
                                    Name="mainCanvas"
                                    Background="White" 
                                    Width="1000" 
                                    Height="1000"
                                    Grid.Row="0"
                                    PointerPressed="Press_Canvas"
                                    PointerMoved="Move_Canvas" 
                                    PointerReleased="Release_Canvas"/>
                    </ScrollViewer>
                    <StackPanel Orientation="Vertical" 
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Top" 
                        Width="50">
                            <Button Content="К"/>
                            <Button Content="Л"/>
                            <Button Content="О"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Bottom" 
                        Width="50">
                            <Button Click="Set_Transform_Mode" Content="XY"/>
                            <Button Click="Set_Rotate_Mode" Content="A"/>
                            <Button Click="Set_Scale_Mode" Content="S"/>
                    </StackPanel>
                </Grid>
                <ScrollViewer Background="LightBlue" VerticalAlignment="Stretch" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <UniformGrid Rows="3" Columns="1" Width="1000">
                        <Rectangle Fill="navy" />
                        <Rectangle Fill="white" />
                        <Rectangle Fill="red" />
                    </UniformGrid>
                </ScrollViewer>
            </Grid>
	    <GridSplitter Grid.Column="3" Background="Gray" Width="6" ResizeDirection="Columns"/>
	    <Grid Grid.Column="4" Background="AliceBlue">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Background="LightBlue" Grid.Row="0">
                    	<Grid DockPanel.Dock="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
							<Button Click="Add_Bone" Grid.Column="0">+</Button>
                            <Button Click="Rename_Bone" Grid.Column="1">R</Button>
						</Grid>
	                    <ScrollViewer
	                        VerticalScrollBarVisibility="Auto">
	                        <TreeView Name="boneTreeView" ItemsSource="{Binding Nodes}">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate ItemsSource="{Binding SubNodes}">
                                        <TextBlock Text="{Binding Title}"/>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
	                    </ScrollViewer>
                    </DockPanel>
                    <GridSplitter Grid.Row="1" Background="Gray" Height="6" ResizeDirection="Rows"/>
                    <DockPanel Background="LightBlue" Grid.Row="2">
                    	<Grid DockPanel.Dock="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
							<Button Click="Add_Image" Grid.Column="0">+</Button>
						</Grid>
	                    <ScrollViewer
	                        VerticalScrollBarVisibility="Auto">
                            <ListBox x:Name="slotsList" ItemsSource="{Binding CurrentProject.Slots}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}" PointerPressed="OnSlotPointerPressed"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
	                    </ScrollViewer>
                    </DockPanel>
                </Grid>
	</Grid>

</DockPanel>

</Window>
