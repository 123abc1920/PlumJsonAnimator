<UserControl
x:Class="SpinejsonEditor.Views.RenameDialog"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:viewModels="clr-namespace:SpinejsonEditor.ViewModels">
    <StackPanel x:DataType="viewModels:MainWindowViewModel">
        <TextBox Name="name" Text="{Binding RedactObj.GetName, Mode=OneWay}"/>
        <Button Click="SetName" Content="Save" />
    </StackPanel>
</UserControl>
