<UserControl
    x:Class="SpinejsonEditor.Views.NewProjectDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:SpinejsonEditor.ViewModels">
    <StackPanel x:DataType="viewModels:MainWindowViewModel">
        <TextBox
            Name="name"
            Text="NewProject1"
            Watermark="Project Name" />

        <StackPanel Orientation="Horizontal">
            <TextBox
                Name="workspace"
                Text=""
                Watermark="Project Path" />
            <Button
                Width="32"
                Height="32"
                Click="SelectFolder">
                <Svg Path="/Assets/bootstrap_icons/folder-fill.svg" />
            </Button>
        </StackPanel>

        <Button Click="CreateProject" Content="Create" />
    </StackPanel>
</UserControl>
