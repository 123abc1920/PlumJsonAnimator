<UserControl
    x:Class="SpinejsonEditor.Views.ExportPanelGIF"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:SpinejsonEditor.ViewModels">
    <StackPanel x:DataType="viewModels:MainWindowViewModel">

        <StackPanel Orientation="Horizontal">
            <TextBox
                Name="path"
                Text=""
                Watermark="Save Path" />
            <Button
                Width="32"
                Height="32"
                Click="SelectFolder">
                <Svg Path="/Assets/bootstrap_icons/folder-fill.svg" />
            </Button>
        </StackPanel>
        <TextBox
            Name="pName"
            Text=""
            Watermark="GIF name" />
        <StackPanel Orientation="Horizontal">
            <TextBox Name="start" />
            <TextBox Name="end" />
        </StackPanel>
        <Button Click="ExportAsGif" Content="Export" />

    </StackPanel>
</UserControl>
