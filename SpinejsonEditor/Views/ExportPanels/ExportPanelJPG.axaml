<UserControl
    x:Class="SpinejsonEditor.Views.ExportPanelJPG"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:SpinejsonEditor.ViewModels">
    <StackPanel x:DataType="viewModels:MainWindowViewModel">

        <StackPanel Orientation="Horizontal">
            <TextBox Name="start" />
            <TextBox Name="end" />
        </StackPanel>
        <Button Click="ExportAsJpg" Content="Export" />

    </StackPanel>
</UserControl>
