<UserControl
    x:Class="SpinejsonEditor.Views.ProjectSettingsPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:SpinejsonEditor.ViewModels">
    <StackPanel x:DataType="viewModels:MainWindowViewModel">
        <TextBlock
            FontSize="16"
            FontWeight="Bold"
            Text="PROJECT SETTINGS" />
        <TextBox Name="pName" Text="{Binding CurrentProject.Name, Mode=OneWay}" Watermark="Project Name" />
        <StackPanel Orientation="Horizontal">
            <TextBox Name="path" Text="{Binding CurrentProject.ProjectPath, Mode=OneWay}" Watermark="Project Path" />
            <Button Click="SelectFolder" Content="O" />
        </StackPanel>
        <TextBox Name="pVersion" Text="{Binding CurrentProject.MetaData.Spine, Mode=OneWay}" Watermark="Spine version" />
        <Button Click="SaveSettings" Content="Save" />
    </StackPanel>
</UserControl>
