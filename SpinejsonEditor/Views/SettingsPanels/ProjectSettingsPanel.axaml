<UserControl
    x:Class="SpinejsonEditor.Views.ProjectSettingsPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:SpinejsonEditor.ViewModels">
    <StackPanel Margin="10" x:DataType="viewModels:MainWindowViewModel">
        <TextBlock
            FontSize="16"
            FontWeight="Bold"
            Text="Project settings" />
        <TextBlock Margin="0,5" Text="Project name:" />
        <TextBox
            Name="pName"
            Text="{Binding CurrentProject.Name, Mode=OneWay}"
            Watermark="Project Name" />
        <TextBlock Margin="0,5" Text="Project path:" />
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
            <TextBox
                Name="path"
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,5,0"
                Text="{Binding CurrentProject.ProjectPath, Mode=OneWay}"
                Watermark="Project Path" />
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Width="32"
                Height="32"
                Click="SelectFolder">
                <Svg Path="/Assets/bootstrap_icons/folder-fill.svg" />
            </Button>
        </Grid>
        <TextBlock Margin="0,5" Text="Spine version for export:" />
        <TextBox
            Name="pVersion"
            Text="{Binding CurrentProject.MetaData.Spine, Mode=OneWay}"
            Watermark="Spine version" />
        <Button
            Margin="0,10"
            HorizontalAlignment="Center"
            Click="SaveSettings"
            Content="Save" />
    </StackPanel>
</UserControl>
