<UserControl
    x:Class="SpinejsonEditor.Views.SpinejsonSettingsPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock
            FontSize="16"
            FontWeight="Bold"
            Text="SPINEJSON SETTINGS" />
        <TextBlock Margin="0,10" Text="Format: JSON" />
        <CheckBox Margin="0,5" Content="Compress" />
        <CheckBox Margin="0,5" Content="Pretty Print" />
        <Slider
            Margin="0,10"
            Maximum="100"
            Minimum="0"
            Value="50" />
    </StackPanel>
</UserControl>
