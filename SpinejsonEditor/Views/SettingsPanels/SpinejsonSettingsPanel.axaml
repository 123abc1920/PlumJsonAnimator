<UserControl
    x:Class="SpinejsonEditor.Views.SpinejsonSettingsPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:SpinejsonEditor.ViewModels">
    <StackPanel x:DataType="viewModels:MainWindowViewModel">
        <TextBlock
            FontSize="16"
            FontWeight="Bold"
            Text="SPINEJSON SETTINGS" />
        <TextBox Margin="0,10" Text="{Binding CurrentProject.ProjectPath, Mode=TwoWay}" />
        <Button Click="SaveSettings" Content="Save" />
    </StackPanel>
</UserControl>
